              "schema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"bazi_calculation\": {\n      \"type\": \"string\",\n      \"description\": \"这是你的【后台推演草稿本】。请在此处列出流日干支与原局发生的全部具体刑冲破害及合局的推论过程。这个字段只供你打草稿，用户看不见。\"\n    },\n    \"review\": {\n      \"type\": \"string\",\n      \"description\": \"基于原局与日柱干支的命理和心理复盘。只输出深度解析纯正文，绝对不要包含“【命理与情绪复盘】”等任何标题或前缀词。\"\n    },\n    \"summary\": {\n      \"type\": \"string\",\n      \"description\": \"去除情绪，针对客观事件精简提取的日志总结。只输出客观事实的纯正文，不要带有任何标题。\"\n    },\n    \"outlook\": {\n      \"type\": \"string\",\n      \"description\": \"明日的起居建议与警言。必须严格依据草稿本中推算出的『明日干支与原局的生克关系』，明确写出具体要防范的十神或五行冲突，并给出命理解法。拒绝泛泛而谈的鸡汤，保持深邃的玄学预测口吻。严禁包含任何前缀标题！\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\n    \"bazi_calculation\",\n    \"review\",\n    \"summary\",\n    \"outlook\"\n  ]\n}\n"
