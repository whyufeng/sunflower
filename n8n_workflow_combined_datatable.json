      "parameters": {
        "jsCode": "const { Lunar } = require('lunar-javascript');\n\nconst messageDate = $input.first().json.RecordDate;\nlet today = new Date();\nif (messageDate) {\n  today = new Date(messageDate);\n}\n\nlet tomorrow = new Date(today);\ntomorrow.setDate(tomorrow.getDate() + 1);\n\n// 依赖 lunar-javascript 库高精度计算农历干支\nconst lunar = Lunar.fromDate(today);\n\nconst yearGz = lunar.getYearInGanZhi();\nconst monthGz = lunar.getMonthInGanZhi();\nconst dayGz = lunar.getDayInGanZhi();\n\nconst lunarTomorrow = Lunar.fromDate(tomorrow);\nconst tmrYearGz = lunarTomorrow.getYearInGanZhi();\nconst tmrMonthGz = lunarTomorrow.getMonthInGanZhi();\nconst tmrDayGz = lunarTomorrow.getDayInGanZhi();\n\nconst items = $input.all();\n\nconst finalString = items.map(item => item.json.msgContent).join(';');\n\nreturn {\n  local_date: today.toISOString(),\n  year_gz: yearGz,\n  month_gz: monthGz,\n  day_gz: dayGz,\n  tmr_year_gz: tmrYearGz,\n  tmr_month_gz: tmrMonthGz,\n  tmr_day_gz: tmrDayGz,\n  message_text: finalString\n};\n"
      },
